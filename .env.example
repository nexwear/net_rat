POSTGRES_USER=netrat
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=netrat
AUTO_APPROVE_DEVICES=true

# Public URL devices use for API + OTA (via nginx /api prefix)
OTA_PUBLIC_BASE_URL=http://15.206.16.137/api

# Machine-to-machine secret (publish scripts, CI). Still accepted as SUPER_ADMIN bearer.
ADMIN_SECRET=change-me

# JWT signing secret for web console sessions
JWT_SECRET=change-me-jwt-secret-use-openssl-rand-hex-32

# Default SUPER_ADMIN seeded on first boot (only if users table is empty)
SUPER_ADMIN_EMAIL=admin@nexwear.io
SUPER_ADMIN_PASSWORD=Nexwear@2025
