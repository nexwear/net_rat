POSTGRES_USER=netrat
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=netrat
AUTO_APPROVE_DEVICES=true

# Public URL devices use for API + OTA (via nginx /api prefix)
OTA_PUBLIC_BASE_URL=http://15.206.16.137/api

# Machine-to-machine secret (publish scripts, CI). Still accepted as SUPER_ADMIN bearer.
ADMIN_SECRET=change-me

# JWT signing secret for web console sessions
JWT_SECRET=change-me-jwt-secret-use-openssl-rand-hex-32

# Default SUPER_ADMIN seeded on first boot (only if users table is empty)
SUPER_ADMIN_EMAIL=admin@nexwear.io
SUPER_ADMIN_PASSWORD=Nexwear@2025

# FCM push notifications — BACKEND ONLY (not google-services.json!)
#
# Firebase console → Project settings → Service accounts → Generate new private key
# That JSON has "type": "service_account" and a "private_key" field.
#
# Option A (Docker): mount the file and set the path
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
#
# Option B: paste the service-account JSON as one line (no line breaks)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"natrat-apprals-tiruppur",...}
#
# The Android app uses android/app/google-services.json (already in the repo).
# Do NOT put google-services.json here — the backend cannot use it.
